# PostgreSQL (Neon en producción; podés usar la misma URL en local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# IPs públicas del Wi-Fi del campus (solo estas pueden votar).
# Para desarrollo local sin restricción: 127.0.0.1,::1,localhost
ALLOWED_CAMPUS_IPS=172.23.1.78,172.25.9.160

# true en Vercel / producción detrás de reverse proxy
TRUST_PROXY=false
